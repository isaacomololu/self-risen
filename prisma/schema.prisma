// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String              @id @default(uuid(4))
  firebaseId            String              @unique
  name                  String
  username              String?
  // password        String
  email                 String              @unique
  avatar                String?
  pushTokens            String[]            @default([])
  streak                Int                 @default(0)
  sessions              Int                 @default(0)
  lastStreakDate        DateTime?
  lastLoggedInAt        DateTime?
  lastLoggedOutAt       DateTime?
  ttsVoicePreference    TtsVoicePreference? @default(ALEX)
  tokensUsedThisMonth   Int                 @default(0)
  tokenLimitPerMonth    Int                 @default(30000) // Default limit: 30k tokens per month
  tokenResetDate        DateTime            @default(now())
  streakReminderEnabled Boolean             @default(true)
  streakReminderTimes   String[]            @default([])
  timezone              String              @default("UTC")
  countryCode           String?
  region                String?
  locationUpdatedAt     DateTime?
  loopTokensRemaining   Int                 @default(5)
  loopTokensResetAt     DateTime?
  loopReminderEnabled   Boolean             @default(false)
  loopReminderTimes     String[]            @default([])
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  wheelOfLife           WheelOfLife?
  reflectionSessions    ReflectionSession[]
  visionBoards          VisionBoard[]
  journals              Journal[]
  streakHistory         StreakHistory[]
  affirmationLoops      AffirmationLoop[]
}

model StreakHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  streak    Int
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
}

model Notification {
  id                String                    @id @default(uuid())
  type              String
  title             String
  body              String
  channels          NotificationChannelType[]
  generatedByUserId String?
  meta              Json                      @default("{}")
  estateId          String?
  iconUrl           String?
  resourceId        String?
  resourceType      String?
  deepLink          String?
  requestId         String                    @unique
  recipients        NotificationRecipient[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([requestId])
  @@index([type])
  @@index([generatedByUserId])
}

model NotificationRecipient {
  id             String       @id @default(uuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  recipientId    String
  isRead         Boolean      @default(false)
  isDismissed    Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([recipientId, notificationId])
  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
  @@index([notificationId])
}

model NotificationAuditLog {
  id               String                  @id @default(uuid())
  requestId        String
  type             String // USER | EXTERNAL
  notificationType String
  recipientId      String
  channel          NotificationChannelType
  provider         String
  status           NotificationStatus
  error            String?
  metadata         Json                    @default("{}")
  sentAt           DateTime?
  createdAt        DateTime                @default(now())

  @@index([recipientId, notificationType, createdAt])
  @@index([requestId, channel])
  @@index([status, createdAt])
  @@index([recipientId, createdAt])
}

model NotificationDeadLetterQueue {
  id               String                  @id @default(uuid())
  requestId        String
  notificationId   String
  userId           String?
  channel          NotificationChannelType
  recipient        String
  notificationType String
  attempts         Int
  lastError        String
  jobData          Json                    @default("{}")
  failedAt         DateTime                @default(now())
  createdAt        DateTime                @default(now())

  @@index([requestId])
  @@index([userId])
  @@index([failedAt])
  @@index([notificationId])
}

model PasswordResetOtp {
  id         String    @id @default(uuid())
  email      String
  otp        String
  expiresAt  DateTime
  isUsed     Boolean   @default(false)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([email])
  @@index([expiresAt])
}

model WheelOfLife {
  id          String            @id @default(uuid())
  userId      String            @unique
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories  WheelCategory[]
  assessments WheelAssessment[]
  focuses     WheelFocus[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
}

model WheelCategory {
  id                 String              @id @default(uuid())
  wheelId            String
  wheel              WheelOfLife         @relation(fields: [wheelId], references: [id], onDelete: Cascade)
  name               String
  order              Int
  focuses            WheelFocus[]
  reflectionSessions ReflectionSession[]
  visionBoard        VisionBoard?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([wheelId])
}

model WheelAssessment {
  id             String       @id @default(uuid())
  wheelId        String
  wheel          WheelOfLife  @relation(fields: [wheelId], references: [id], onDelete: Cascade)
  scores         Json
  strongestArea  String?
  weakestArea    String?
  imbalanceScore Float?
  focuses        WheelFocus[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([wheelId])
  @@index([wheelId, createdAt])
}

model WheelFocus {
  id                 String              @id @default(uuid())
  wheelId            String
  wheel              WheelOfLife         @relation(fields: [wheelId], references: [id], onDelete: Cascade)
  categoryId         String
  category           WheelCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isActive           Boolean             @default(true)
  startedAt          DateTime            @default(now())
  completedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  wheelAssessment    WheelAssessment?    @relation(fields: [wheelAssessmentId], references: [id])
  wheelAssessmentId  String?
  reflectionSessions ReflectionSession[]

  @@index([wheelId])
  @@index([categoryId])
  @@index([wheelId, isActive])
}

model ReflectionSession {
  id                          String                  @id @default(uuid())
  userId                      String
  user                        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId                  String?
  category                    WheelCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  wheelFocusId                String?
  wheelFocus                  WheelFocus?             @relation(fields: [wheelFocusId], references: [id], onDelete: SetNull)
  isGlobal                    Boolean                 @default(false)
  prompt                      String?
  rawBeliefText               String?
  audioUrl                    String?
  transcriptionText           String?
  limitingBelief              String?
  selectedAffirmationText     String?
  selectedAffirmationAudioUrl String?
  userAffirmationAudioUrl     String?
  playbackCount               Int                     @default(0)
  lastPlayedAt                DateTime?
  beliefRerecordedAt          DateTime?
  beliefRerecordCount         Int                     @default(0)
  status                      ReflectionSessionStatus @default(PENDING)
  isVision                    Boolean                 @default(false)
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  completedAt                 DateTime?
  vision                      Vision[]
  waves                       Wave[]
  affirmations                Affirmation[]
  reflectionSound             ReflectionSound?

  @@index([userId])
  @@index([categoryId])
  @@index([wheelFocusId])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model Wave {
  id           String            @id @default(uuid())
  sessionId    String
  session      ReflectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  startDate    DateTime
  endDate      DateTime
  durationDays Int
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([sessionId, isActive])
  @@index([endDate, isActive])
}

model Affirmation {
  id                 String                @id @default(uuid())
  sessionId          String
  session            ReflectionSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  affirmationText    String
  audioUrl           String?
  isSelected         Boolean               @default(false)
  order              Int                   @default(0)
  ttsVoicePreference TtsVoicePreference?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  loopItems          AffirmationLoopItem[]

  @@index([sessionId])
  @@index([sessionId, isSelected])
  @@index([sessionId, order])
}

model AffirmationLoop {
  id                 String                @id @default(uuid())
  userId             String
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             AffirmationLoopStatus @default(PROCESSING)
  audioPath          String?
  durationSeconds    Int?
  backgroundMusicKey String
  voicePreference    TtsVoicePreference?
  errorMessage       String?
  name               String?
  description        String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  items              AffirmationLoopItem[]

  @@index([userId, createdAt])
  @@index([userId, status])
}

model AffirmationLoopItem {
  loopId        String
  affirmationId String
  sortOrder     Int
  loop          AffirmationLoop @relation(fields: [loopId], references: [id], onDelete: Cascade)
  affirmation   Affirmation     @relation(fields: [affirmationId], references: [id], onDelete: Cascade)

  @@id([loopId, affirmationId])
  @@unique([loopId, sortOrder])
  @@index([affirmationId])
}

model VisionBoard {
  id         String         @id @default(uuid())
  categoryId String?        @unique
  category   WheelCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  visions    Vision[]
  name       String?
  isGloabal  Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([userId, isGloabal])
  @@index([userId, name])
}

model Vision {
  id                  String             @id @default(uuid())
  visionBoardId       String
  visionBoard         VisionBoard        @relation(fields: [visionBoardId], references: [id], onDelete: Cascade)
  reflectionSessionId String?
  reflectionSession   ReflectionSession? @relation(fields: [reflectionSessionId], references: [id], onDelete: Cascade)
  imageUrl            String?
  order               Int?
  visionSoundId       String?            @map("backgroundSoundId")
  visionSound         VisionSound?       @relation(fields: [visionSoundId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([visionBoardId, reflectionSessionId])
  @@index([visionBoardId])
  @@index([reflectionSessionId])
  @@index([visionBoardId, order])
}

model Journal {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  title     String
  text      String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, date])
}

model ReflectionSound {
  id                  String            @id @default(uuid())
  reflectionSessionId String            @unique
  reflectionSession   ReflectionSession @relation(fields: [reflectionSessionId], references: [id], onDelete: Cascade)
  soundUrl            String
  name                String?
  fileSize            Int?
  mimeType            String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model VisionSound {
  id        String   @id @default(uuid())
  soundUrl  String
  name      String?  @map("fileName")
  fileSize  Int?
  mimeType  String?
  order     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  visions   Vision[]

  @@map("VisionBoardSound")
}

enum NotificationChannelType {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum ReflectionSessionStatus {
  PENDING
  BELIEF_CAPTURED
  AFFIRMATION_GENERATED
  COMPLETED
}

enum AffirmationLoopStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum TtsVoicePreference {
  SAGE // Nova - Empathetic Mentor
  PHOENIX // Shimmer - Energetic Motivator
  RIVER // Onyx - Confident Coach
  QUINN // Echo - Friendly Guide
  ALEX // Alloy - Calm Companion
  ROBIN // Fable - Wise Advisor
}
